{
  "name": "SmartCity Light iOS",
  "dataColors": [
    "#007AFF",
    "#34C759",
    "#FF9500",
    "#AF52DE",
    "#5AC8FA",
    "#FF3B30",
    "#FFCC00",
    "#8E8E93"
  ],
  "background": "#F2F2F7",
  "foreground": "#1C1C1E",
  "tableAccent": "#007AFF",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 14,
      "color": "#1C1C1E"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#6E6E73"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 28,
      "color": "#1C1C1E"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E5E5EA" } }, "radius": 14 }],
        "shadow": [{ "show": true, "color": { "solid": { "color": "#000000" } }, "transparency": 92, "blur": 8, "angle": 90, "distance": 2 }],
        "outline": [{ "color": { "solid": { "color": "#E5E5EA" } }, "weight": 1 }]
      }
    },
    "card": {
      "*": {
        "labels": [{ "color": { "solid": { "color": "#1C1C1E" } }, "fontSize": 28, "fontFamily": "Segoe UI Semibold" }],
        "categoryLabels": [{ "color": { "solid": { "color": "#6E6E73" } }, "fontSize": 11 }]
      }
    },
    "slicer": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#FFFFFF" } } }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E5E5EA" } }, "radius": 10 }]
      }
    }
  }
}
